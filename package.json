{
  "name": "@dera-/namagame-creator-app-win",
  "version": "1.0.4",
  "description": "Nicolive game generator",
  "main": "script/main.js",
  "targets": {
    "main": false
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p ./ && node tools/copy-assets.js",
    "start": "npm run build && electron .",
    "prepare:mcp": "node tools/prepare-embedded-mcp.js",
    "pack": "npm run prepare:mcp && npm run build && node tools/validate-rollup-native.cjs && electron-builder",
    "test": "node --import tsx --test src/main/__tests__/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "dera-/namagame-creator-app-win.git"
  },
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.26.2",
  "dependencies": {
    "@akashic/akashic-cli-commons": "~1.0.3",
    "@akashic/akashic-cli-export": "~2.0.12",
    "@akashic/akashic-cli-sandbox": "^2.0.7",
    "@akashic/akashic-cli-serve": "^2.0.19",
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.1.7",
    "openai": "^6.15.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^25.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.namagame.creator",
    "productName": "Namagame Creator",
    "executableName": "namagame-creator",
    "mac": {
      "target": [
        "zip"
      ]
    },
    "linux": {
      "target": [
        "zip"
      ]
    },
    "win": {
      "target": [
        "zip"
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "script/**",
      "akashic-mcp/**",
      "package.json",
      "node_modules/**"
    ],
    "asar": true,
    "asarUnpack": [
      "akashic-mcp/**",
      "node_modules/@akashic/akashic-cli-export/node_modules/@rollup/**",
      "node_modules/@akashic/akashic-cli-export/node_modules/rollup/dist/*.node"
    ],
    "extraResources": [
      {
        "from": "akashic-mcp",
        "to": "akashic-mcp",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "dera-",
        "repo": "namagame-creator-app-win"
      }
    ]
  }
}
